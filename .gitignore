# Tripple Exchange - .gitignore

# Development and Testing Files
test-database.php
test-*.php
debug-*.php
*.test.js
*.test.html

# Logs and Error Files
*.log
error_log
*.error
logs/
*.debug

# Configuration Files (if they contain sensitive data)
config.local.php
.env
.env.local
.env.production

# Cache and Temporary Files
cache/
tmp/
temp/
*.tmp
*.cache

# Database Backups
*.sql.backup
database_backup_*
*.dump

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node.js (if used for build tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build and Distribution
dist/
build/
public/build/

# User Uploads (sensitive)
uploads/
user_files/
documents/

# Session Files
sessions/
*.sess

# Backup Files
*.backup
*.bak
*.orig

# OS Generated Files
*.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Security Files
*.key
*.pem
*.crt
ssl/
certificates/

# Composer (if used)
vendor/
composer.lock